# Polymarket Configuration
# Your Ethereum private key (hex, without 0x prefix)
POLYMARKET_PRIVATE_KEY=your_private_key_here
# Chain ID: 137 for Polygon mainnet
POLYMARKET_CHAIN_ID=137
# Optional: Funder address if using proxy wallets
POLYMARKET_FUNDER_ADDRESS=

# Kalshi Configuration
# API key ID from your Kalshi account
KALSHI_API_KEY_ID=your_api_key_id_here
# Path to your Kalshi private key file (.pem)
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Risk Management
# Maximum USD per single trade (each leg)
MAX_POSITION_SIZE=50
# Maximum total USD exposure across all open positions
MAX_TOTAL_EXPOSURE=500
# Maximum number of concurrent open positions
MAX_CONCURRENT_POSITIONS=10
# Minimum edge (%) after fees to consider an opportunity
MIN_EDGE_PERCENT=1.0

# Scanner Settings
# How often to scan for opportunities (seconds)
SCAN_INTERVAL_SECONDS=10

# Execution Mode: "semi" or "auto"
EXECUTION_MODE=semi
